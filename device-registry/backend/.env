# Database
MONGODB_URI=mongodb://127.0.0.1:27017/drts_rwanda

# JWT
JWT_SECRET=drts-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# OTP Settings
OTP_EXPIRY_MINUTES=5

# QR Code
QR_EXPIRY_MINUTES=15
QR_SECRET=drts-qr-hmac-secret-key

# Frontend URL (for QR verification links)
FRONTEND_URL=http://localhost:3000
