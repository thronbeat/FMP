# Database
MONGODB_URI=mongodb://127.0.0.1:27017/drts_rwanda

# JWT
JWT_SECRET=drts-development-secret-key-2024
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5001
NODE_ENV=development

# SMS Service (Africa's Talking) - Use sandbox for development
AT_API_KEY=sandbox
AT_USERNAME=sandbox
AT_SENDER_ID=DRTS

# QR Code
QR_SECRET=drts-qr-secret-key-2024
QR_EXPIRY_MINUTES=15
